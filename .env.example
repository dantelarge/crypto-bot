# Copy this file to .env and fill in your values

# Server
PORT=3000

# Binance API Keys (only needed for LIVE trading — not needed for paper trading or backtesting)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# Set to "paper" for fake money trading, "live" for real trading
TRADE_MODE=paper

# Starting paper trading balance in USDT
PAPER_BALANCE=1000
